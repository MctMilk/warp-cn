# 编码面板 / 代码审查 UI 字符串。
# Keys MUST start with `coding-`.

# 评论编辑器 / 文件树 / 本地编辑器
coding-comment-imported-from-github = 评论从 GitHub 导入
coding-project-explorer-unavailable = 项目浏览器不可用
coding-file-stale-warning = 该文件已有保存的更改，此处尚未反映。

# 代码审查主视图
coding-error-loading-diffs = 加载差异时出错
coding-cannot-detect-diffs = 无法检测此目录中的差异
coding-no-open-changes = 暂无未提交的更改
coding-no-open-changes-desc = 当你或智能体作出更改时，可在此查看。
coding-diff-too-large = 差异内容过大，无法渲染
coding-binary-no-diff = 二进制文件 — 无可显示差异
coding-file-renamed-no-change = 文件仅重命名，内容未改
coding-new-empty-file = 新建空文件
coding-unable-to-load-content = 无法加载文件内容
coding-no-file-selected = 未选择文件
coding-no-files-to-discard = 没有可丢弃的文件

# 评论渲染
coding-comment-outdated = 已过期
coding-comment-from-github = 来自 GitHub

# 差异菜单
coding-no-matches = 无匹配项

# 标签页会话配置
coding-auto-create-worktree = 打开新标签页时自动创建工作树
coding-auto-worktree-branch-name = 自动生成工作树分支名

# Git 对话框
coding-git-changes = 更改
coding-git-include-unstaged = 包含未暂存
coding-git-commit-message = 提交信息
coding-git-branch = 分支
coding-git-included-commits = 包含的提交
coding-loading = 加载中…
