# 客户端对话框 / 模态窗口通用字符串。
# Keys MUST start with `dialog-`.

dialog-close = 关闭
dialog-cancel = 取消
dialog-confirm = 确认
dialog-save = 保存
dialog-discard = 放弃
dialog-dont-save = 不保存
dialog-yes = 是
dialog-no = 否
dialog-yes-close = 是，关闭
dialog-yes-quit = 是，退出
dialog-show-running-processes = 显示正在运行的进程
dialog-close-pane = 关闭窗格？
dialog-close-tab = 关闭标签页？
dialog-close-tabs = 关闭标签页？
dialog-close-window = 关闭窗口？
dialog-quit-warp = 退出 Warp？
dialog-save-changes = 保存更改？
