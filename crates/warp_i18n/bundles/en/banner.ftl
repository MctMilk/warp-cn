# Banner / in-app announcement strings.
# Keys MUST start with `banner-`.

# Notifications discovery / error banner
banner-notifications-set-permissions = Set permissions
banner-notifications-troubleshoot = Troubleshoot
banner-notifications-learn-more = Learn more
banner-notifications-enable = Enable
banner-notifications-configure = Configure notifications
banner-notifications-dismissed = We won't show this banner again, but you can always go to Settings to enable notifications.
banner-notifications-disabled = Notifications were turned off, but you can always go to Settings to enable notifications.
banner-notifications-permissions-accepted = Success! You are now ready to receive desktop notifications.
banner-notifications-permissions-denied = Warp was denied permissions to send you notifications.
banner-notifications-permissions-error = Something went wrong while requesting permissions.
banner-notifications-permissions-pending = Don't forget to 'Allow' the permissions request to finish setting up notifications.
banner-notifications-trigger-long-running = Warp can notify you when long-running commands finish.
banner-notifications-trigger-agent-task = Warp can notify you when an agent finishes responding.
banner-notifications-trigger-needs-attention = Warp can notify you when a command or agent needs your attention.
banner-notifications-trigger-password = Warp can notify you when you're prompted to enter a password.
banner-notifications-a11y-help = You can enable notifications through the command palette.

# Notifications error banner titles + a11y help
banner-notifications-error-title-permissions = Warp tried to send you a notification for the last block but does not have permission.
banner-notifications-error-title-other = Warp tried to send you a notification for the last block, but something went wrong.
banner-notifications-error-title-generic = Error sending notification
banner-notifications-error-a11y-help = Make sure you have enabled access for Warp notifications in System Preferences.

# AWS Bedrock inline banners
banner-aws-bedrock-enabled = Your Warp admin has enabled AWS Bedrock for your team.
banner-aws-cli-required = The AWS CLI is required to authenticate with your organization's AWS Bedrock. Install it to continue.
